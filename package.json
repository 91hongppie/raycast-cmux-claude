{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cmux-claude",
  "title": "cmux Claude Sessions",
  "description": "Send commands to idle Claude Code sessions in cmux directly from Raycast",
  "icon": "extension-icon.png",
  "author": "",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Claude Sessions",
      "description": "List idle Claude Code sessions and send next commands",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "cmuxPassword",
      "type": "password",
      "required": false,
      "title": "cmux Socket Password",
      "description": "cmux Settings에서 설정한 socket password",
      "placeholder": "password"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
